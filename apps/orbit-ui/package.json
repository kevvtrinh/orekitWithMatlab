{
  "name": "orbit-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Web-based mission console for the MATLAB/Orekit suite (React + Three.js frontend, Node bridge to MATLAB).",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "bridge:demo": "node server/runBridgeCli.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.7"
  }
}
